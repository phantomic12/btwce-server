# Runtime artifacts (created by start.sh / server)
downloads/
libraries/
world/
logs/
backups/

# Generated by the server / loader
fabric-server-launcher.properties
server.log
fabricloader.log
*.pid

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

